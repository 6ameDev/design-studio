{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(npm install *)",
      "Bash(npm i *)",
      "Bash(npm add *)",
      "Bash(npx *)"
    ],
    "allow": [
      "Bash(npm run *)",
      "Bash(npm ci)",
      "Bash(npm start)",
      "Bash(npm test)",
      "Bash(npm run dev)",
      "Bash(npm run build)"
    ]
  },
  "companyAnnouncements": [
    "Welcome to Design Studio! Your AI assistant will help you build real UIs.",
    "Security tip: Always use the project's npm wrapper. Do not bypass it."
  ]
}
