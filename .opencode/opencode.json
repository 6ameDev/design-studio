{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "npm install *": "deny",
      "npm i *": "deny",
      "npm add *": "deny",
      "npx *": "deny",
      "npm run *": "allow",
      "npm ci": "allow",
      "npm start": "allow",
      "npm test": "allow",
      "npm run dev": "allow",
      "npm run build": "allow"
    }
  }
}
